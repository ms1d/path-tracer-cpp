{
	"version": 3,
	"configurePresets": [
		{
			"name": "dev",
			"displayName": "Development",
			"generator": "Ninja",
			"binaryDir": "build/dev",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"BUILD_TESTS": "ON",
				"CMAKE_CXX_FLAGS": "-g -Wall -Wextra -Wpedantic -Og",
				"CMAKE_CUDA_FLAGS": "-g -lineinfo -Xcompiler -Wall"
			}
		},

		{
			"name": "rel",
			"displayName": "Release",
			"generator": "Ninja",
			"binaryDir": "build/rel",
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
				"CMAKE_BUILD_TYPE": "Release",
				"BUILD_TESTS": "OFF",
				"CMAKE_CXX_FLAGS": "-O3 -DNDEBUG -flto",
				"CMAKE_CUDA_FLAGS": "-O3 --use_fast_math"
			}
		}
	],

	"buildPresets": [
		{
			"name": "dev",
			"configurePreset": "dev"
		},
		{
			"name": "rel",
			"configurePreset": "rel"
		}
	]
}
